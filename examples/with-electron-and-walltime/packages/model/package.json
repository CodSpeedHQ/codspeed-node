{
  "name": "@mail-client-demo/model",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mail-client backend-for-frontend model (Email, Inbox, seed). Benchmarked under CodSpeed.",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "bench": "vitest bench --run",
