    "bench:codspeed:memory": "codspeed run --mode memory pnpm bench",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@codspeed/tinybench-plugin": "^5.4.0",
    "@codspeed/vitest-plugin": "^5.4.0",
    "@types/node": "^25.9.1",
    "tinybench": "^6.0.2",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  }
}
